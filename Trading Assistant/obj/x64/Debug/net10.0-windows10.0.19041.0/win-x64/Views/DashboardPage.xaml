<Page x:ConnectionId='1'
    x:Class="Trading_Assistant.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Trading_Assistant.Models"
    xmlns:dtos="using:Trading_Assistant.IPC.Messages.DTOs"
    xmlns:vm="using:Trading_Assistant.ViewModels"
    x:Name="PageRoot"
    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT PANEL ═══════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,16,12,16">
                <StackPanel Spacing="16">

                    <!-- Service -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Service" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:ConnectionId='44'                                                     
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="280"/>
                            <ProgressRing x:ConnectionId='45'                                                     
                                          Width="16" Height="16"
                                          VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button x:ConnectionId='41' Content="Connect"
                                                                                    
                                HorizontalAlignment="Stretch"/>
                        <Button x:ConnectionId='42' Content="Refresh"
                                                                               
                                                                                       
                                HorizontalAlignment="Stretch"/>
                        <Button x:ConnectionId='43' Content="Run Analysis"
                                                                                   
                                                                                       
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <!-- Portfolio Config -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Portfolio" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <NumberBox x:ConnectionId='38' Header="Available Capital ($)"
                                                                                           
                                   Minimum="0"
                                   SpinButtonPlacementMode="Compact"
                                   HorizontalAlignment="Stretch"/>
                        <ComboBox x:ConnectionId='39' Header="Risk Profile"
                                                                                                          
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Conservative"/>
                            <ComboBoxItem Content="Moderate"/>
                            <ComboBoxItem Content="Aggressive"/>
                        </ComboBox>
                        <Button x:ConnectionId='40' Content="Save Portfolio"
                                                                                 
                                                                                       
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <!-- Watched Assets -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Watched Assets" Style="{StaticResource SubtitleTextBlockStyle}"/>

                        <ListView x:ConnectionId='26'                                                            
                                  SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate                                  >
                                    <Border x:ConnectionId='32' Padding="0,8"
                                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock x:ConnectionId='36'                                    
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock x:ConnectionId='37'                                  
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock x:ConnectionId='34'                                  
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <NumberBox x:ConnectionId='35'                                          
                                                           PlaceholderText="Shares owned"
                                                           Minimum="0"
                                                           SmallChange="1"
                                                           SpinButtonPlacementMode="Hidden"
                                                           FontSize="12"
                                                           HorizontalAlignment="Stretch"/>
                                            </StackPanel>
                                            <Button x:ConnectionId='33' Grid.Column="1"
                                                    Content="✕"
                                                    Command="{Binding ViewModel.RemoveAssetCommand, ElementName=PageRoot}"
                                                                               
                                                    VerticalAlignment="Center"
                                                    Padding="8,4"
                                                    FontSize="11"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Add Asset Form -->
                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="4"
                                Padding="10">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Add asset"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBox x:ConnectionId='27' PlaceholderText="Symbol (e.g. AAPL)"
                                                                                              />
                                <TextBox x:ConnectionId='28' PlaceholderText="Name (e.g. Apple Inc.)"
                                                                                            />
                                <ComboBox x:ConnectionId='29'                                                                       
                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Stock"/>
                                    <ComboBoxItem Content="ETF"/>
                                    <ComboBoxItem Content="Crypto"/>
                                    <ComboBoxItem Content="Forex"/>
                                </ComboBox>
                                <Button x:ConnectionId='30' Content="Add Asset"
                                                                                    
                                        HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══ RIGHT PANEL ══════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="16">
            <StackPanel Spacing="16">

                <!-- Market Summary -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="Market Summary" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <TextBlock x:ConnectionId='25'                                                        
                                       VerticalAlignment="Center"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:ConnectionId='24'                                               
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyTextBlockStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Risk & Sentiment -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Risk Assessment" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <TextBlock x:ConnectionId='23'                                                      
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Market Sentiment" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <TextBlock x:ConnectionId='22'                                                       
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Trading Opportunities -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Trading Opportunities" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="10"
                                    Padding="8,2"
                                    VerticalAlignment="Center">
                                <TextBlock x:ConnectionId='21'                                                           
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="12"/>
                            </Border>
                        </StackPanel>
                        <ListView x:ConnectionId='11'                                                            
                                  SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate                                 >
                                    <Border x:ConnectionId='13' Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="12"
                                            Margin="0,4">
                                        <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock x:ConnectionId='18'                       
                                                           FontWeight="SemiBold"
                                                           FontSize="15"/>
                                                <TextBlock x:ConnectionId='19'                          
                                                           FontWeight="SemiBold"
                                                           Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                                <Border Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                                        CornerRadius="4"
                                                        Padding="6,2">
                                                    <TextBlock x:ConnectionId='20'                                 FontSize="11"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock x:ConnectionId='14'                       
                                                       TextWrapping="Wrap"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="16">
                                                <TextBlock FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                                    <Run Text="Target: "/>
                                                    <Run x:ConnectionId='17'                                />
                                                </TextBlock>
                                                <TextBlock FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                                    <Run Text="Stop: "/>
                                                    <Run x:ConnectionId='16'                             />
                                                </TextBlock>
                                                <TextBlock x:ConnectionId='15'                          
                                                           FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Portfolio Positions -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="My Positions" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <TextBlock x:ConnectionId='10'                                                          
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                        </StackPanel>
                        <ListView x:ConnectionId='2'                                                                
                                  SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate                              >
                                    <Border x:ConnectionId='4' Padding="4,8"
                                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:ConnectionId='5' Grid.Column="0"
                                                                             
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock x:ConnectionId='6' Grid.Column="1"
                                                                           
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock x:ConnectionId='7' Grid.Column="2"
                                                                                
                                                       Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                <TextBlock FontSize="13" FontWeight="SemiBold">
                                                    <Run x:ConnectionId='9'                           />
                                                </TextBlock>
                                                <TextBlock Text="shares"
                                                           FontSize="10"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock x:ConnectionId='8' Grid.Column="4"
                                                                                         
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

