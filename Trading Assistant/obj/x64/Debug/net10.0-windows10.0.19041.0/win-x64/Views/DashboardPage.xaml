<Page x:ConnectionId='1'
    x:Class="Trading_Assistant.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,24">
            <TextBlock Text="Trading Dashboard" Style="{StaticResource TitleTextBlockStyle}"/>
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock x:ConnectionId='14' x:Name="StatusText"
                                                                               
                           Style="{StaticResource BodyTextBlockStyle}"
                           VerticalAlignment="Center"/>
                <ProgressRing x:ConnectionId='15' x:Name="LoadingRing"
                                                                                  
                              Width="20" Height="20"/>
            </StackPanel>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,24">
            <Button x:ConnectionId='11' Content="Refresh"
                                                                   
                    Style="{StaticResource AccentButtonStyle}"/>
            <Button x:ConnectionId='12' Content="Run Analysis"
                                                                       
                                                                           />
            <Button x:ConnectionId='13' x:Name="ReconnectButton"
                    Content="Reconnect"
                                                                        />
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="2">
            <StackPanel Spacing="16">

                <!-- Summary Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Market Summary" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock x:ConnectionId='9' x:Name="SummaryText"
                                                                                 
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyTextBlockStyle}"/>
                        <TextBlock x:ConnectionId='10' x:Name="LastAnalysisText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Opportunities -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Trading Opportunities" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="10"
                                    Padding="8,2"
                                    VerticalAlignment="Center">
                                <TextBlock x:ConnectionId='8' x:Name="OpportunityCount"
                                           Text="0"
                                           Foreground="White"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>

                        <!-- Opportunities List -->
                        <ListView x:ConnectionId='6' x:Name="OpportunitiesList"
                                                                                             
                                  SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="12"
                                            Margin="0,4">
                                        <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Symbol}"
                                                           FontWeight="SemiBold"
                                                           FontSize="16"/>
                                                <TextBlock Text="-"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock Text="{Binding Direction}"
                                                           FontWeight="SemiBold"/>
                                                <Border Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                                        CornerRadius="4"
                                                        Padding="6,2">
                                                    <TextBlock Text="{Binding ConfidenceLevel}"
                                                               FontSize="12"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Reason}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{Binding Timeframe}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Risk & Sentiment -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Risk Assessment" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <TextBlock x:ConnectionId='5'                                                      
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Market Sentiment" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <TextBlock x:ConnectionId='4'                                                       
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Service Info -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Next Scheduled Analysis"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:ConnectionId='3' x:Name="NextAnalysisText"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Watched Assets"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:ConnectionId='2' x:Name="WatchedAssetsText"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

