<Page
    x:Class="Trading_Assistant.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="using:Trading_Assistant.Converters"
    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,24">
            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}"/>
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Style="{StaticResource BodyTextBlockStyle}"
                           VerticalAlignment="Center"/>
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Width="20" Height="20"
                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"/>
            </StackPanel>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="24" MaxWidth="800">

                <!-- Trading Configuration -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Trading Configuration" Style="{StaticResource SubtitleTextBlockStyle}"/>

                        <NumberBox Header="Available Capital (CHF)"
                                   Value="{x:Bind ViewModel.AvailableCapital, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}"
                                   SpinButtonPlacementMode="Inline"
                                   SmallChange="100"
                                   LargeChange="1000"
                                   Minimum="0"/>

                        <ComboBox Header="Risk Profile"
                                  ItemsSource="{x:Bind ViewModel.RiskProfiles}"
                                  SelectedIndex="{x:Bind ViewModel.SelectedRiskProfileIndex, Mode=TwoWay}"
                                  Width="200"/>

                        <Button Content="Save Trading Config"
                                Command="{x:Bind ViewModel.SaveTradingConfigCommand}"
                                Style="{StaticResource AccentButtonStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Watched Assets -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Watched Assets" Style="{StaticResource SubtitleTextBlockStyle}"/>

                        <!-- Add New Asset Form -->
                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="4"
                                Padding="12">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Add New Asset"
                                           FontWeight="SemiBold"
                                           Style="{StaticResource BodyTextBlockStyle}"/>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Header="Symbol"
                                             PlaceholderText="AAPL"
                                             Text="{x:Bind ViewModel.NewAssetSymbol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             CharacterCasing="Upper"/>

                                    <TextBox Grid.Column="1"
                                             Header="Name"
                                             PlaceholderText="Apple Inc."
                                             Text="{x:Bind ViewModel.NewAssetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <ComboBox Grid.Column="2"
                                              Header="Type"
                                              ItemsSource="{x:Bind ViewModel.AssetTypes}"
                                              SelectedIndex="{x:Bind ViewModel.SelectedAssetTypeIndex, Mode=TwoWay}"/>

                                    <Button Grid.Column="3"
                                            Content="Add"
                                            Command="{x:Bind ViewModel.AddAssetCommand}"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,0,1"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Assets List -->
                        <ListView ItemsSource="{x:Bind ViewModel.WatchedAssets, Mode=OneWay}"
                                  SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="8" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Symbol}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <Border Grid.Column="2"
                                                Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                                                CornerRadius="4"
                                                Padding="8,4"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Type}"
                                                       FontSize="12"/>
                                        </Border>

                                        <Button Grid.Column="3"
                                                Content="Remove"
                                                CommandParameter="{Binding}"
                                                Click="OnRemoveAssetClick"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Empty State -->
                        <TextBlock Text="No assets configured. Add assets above to start tracking."
                                   Visibility="{x:Bind ViewModel.WatchedAssets.Count, Mode=OneWay, Converter={StaticResource CountToVisibilityInverseConverter}}"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- About Section -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="About" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="Trading Assistant"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Automated market analysis powered by Claude AI"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Version 2.0.0"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   Style="{StaticResource CaptionTextBlockStyle}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
